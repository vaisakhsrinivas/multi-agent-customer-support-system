# Copy to .env and fill in (never commit .env).

# --- Supabase CLI: link + db push to your hosted project ---
# Create at: https://supabase.com/dashboard/account/tokens
# This is a Personal Access Token (often starts with sbp_). It is NOT the anon or service_role JWT.
SUPABASE_ACCESS_TOKEN=

# Project ref: Dashboard URL is https://supabase.com/dashboard/project/<PROJECT_REF>
SUPABASE_PROJECT_REF=

# Database password you chose when creating the project (Settings → Database).
# Used by the CLI to run migrations against the remote DB.
SUPABASE_DB_PASSWORD=

# --- Optional: run seed on cloud via scripts/seed-remote.sh ---
# Settings → Database → Connection string → URI (replace [YOUR-PASSWORD]).
SUPABASE_DB_URL=

# --- App / agents (Settings → API) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google ADK (Gemini) ---
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: model id for all agents in this app
# ADK_MODEL=gemini-2.5-flash

# --- Return A2A service + SupportRouter RemoteA2aAgent ---
# Run: python -m services.return_a2a (defaults below must match)
# RETURN_A2A_HOST=127.0.0.1
# RETURN_A2A_PORT=8001
# RETURN_A2A_PROTOCOL=http
# Or full card URL:
# RETURN_A2A_CARD_URL=http://127.0.0.1:8001/.well-known/agent-card.json
# Omit ReturnsSpecialist if you are not running the return server:
# RETURN_A2A_DISABLED=true

# --- Langfuse / OpenTelemetry (optional) ---
# pip install -r requirements-observability.txt
# LANGFUSE_ENABLED=1
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# EU cloud (default): https://cloud.langfuse.com
# US cloud: LANGFUSE_HOST=https://us.cloud.langfuse.com
# Self-hosted: LANGFUSE_HOST=http://localhost:3000
# Richer Gemini spans (optional; may duplicate ADK spans — validate in UI):
# LANGFUSE_OPENINFERENCE=1
# Or set OTLP yourself (HTTP/protobuf only; Langfuse does not support gRPC OTLP):
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(pk:sk)>,x-langfuse-ingestion-version=4
# Prompt/response text in spans (PII risk — default often redacted):
# ADK_CAPTURE_MESSAGE_CONTENT_IN_SPANS=true
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# --- pytest integration + mini eval (optional; usually export in shell, not required in .env) ---
# RUN_INTEGRATION_TESTS=1   # tests/test_support_scenarios.py
# RUN_MINI_EVAL=1           # tests/test_mini_eval.py — see eval/README.md
