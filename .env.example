# Copy to .env and fill in (never commit .env).

# --- Supabase CLI: link + db push to your hosted project ---
# Create at: https://supabase.com/dashboard/account/tokens
# This is a Personal Access Token (often starts with sbp_). It is NOT the anon or service_role JWT.
SUPABASE_ACCESS_TOKEN=

# Project ref: Dashboard URL is https://supabase.com/dashboard/project/<PROJECT_REF>
SUPABASE_PROJECT_REF=

# Database password you chose when creating the project (Settings → Database).
# Used by the CLI to run migrations against the remote DB.
SUPABASE_DB_PASSWORD=

# --- Optional: run seed on cloud via scripts/seed-remote.sh ---
# Settings → Database → Connection string → URI (replace [YOUR-PASSWORD]).
SUPABASE_DB_URL=

# --- App / agents (Settings → API) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google ADK (Gemini) ---
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Optional: model id for all agents in this app
# ADK_MODEL=gemini-2.5-flash

# --- Return A2A service + SupportRouter RemoteA2aAgent ---
# Run: python -m services.return_a2a (defaults below must match)
# RETURN_A2A_HOST=127.0.0.1
# RETURN_A2A_PORT=8001
# RETURN_A2A_PROTOCOL=http
# Or full card URL:
# RETURN_A2A_CARD_URL=http://127.0.0.1:8001/.well-known/agent-card.json
# Omit ReturnsSpecialist if you are not running the return server:
# RETURN_A2A_DISABLED=true

# --- pytest integration scenarios (tests/test_support_scenarios.py) ---
# RUN_INTEGRATION_TESTS=1
