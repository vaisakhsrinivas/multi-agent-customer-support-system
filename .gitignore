# --- Environment & secrets (never commit) ---
.env
.env.*
!.env.example
.env.local
.env.*.local
# Env files without a leading dot (e.g. secrets.env) — not matched by .env / .env.*
*.env
.envrc
.netrc
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.keystore
credentials.json
*-credentials.json
service-account*.json
*secret*.json
.secrets/
secrets/
application_default_credentials.json
gcloud-*.json

# --- API / auth tokens (common filenames) ---
.token
.tokens
.auth
*.token

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
*.egg-info/
.eggs/
dist/
build/
*.egg
.mypy_cache/
.pytest_cache/
.ruff_cache/
.tox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/
__pypackages__/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- IDE & editors ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Logs & local scratch ---
*.log
.cache/
*.sqlite
*.sqlite3

# --- Mypy daemon metadata (optional local tooling) ---
.dmypy.json

# --- Google ADK (local session DB and dev state under each agent package) ---
**/.adk/

# --- Docker (local overrides often hold secrets) ---
docker-compose.override.yml

# --- Supabase CLI (also listed in supabase/.gitignore) ---
supabase/.temp/
supabase/.branches/
